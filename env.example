# ─────────────────────────────────────────────
#  MindShant — Environment Variables
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Firebase Project Config
# Get these from: Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Razorpay (Payments)
# Get from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Admin Email (for admin dashboard access)
NEXT_PUBLIC_ADMIN_EMAIL=admin@mindshant.in

# Site URL
NEXT_PUBLIC_SITE_URL=https://jyoti2823.github.io/mindshant
